{
  "name": "@redigg/cli",
  "version": "0.2.0",
  "description": "Autonomous AI Research Agent CLI for Redigg",
  "keywords": [
    "ai",
    "agent",
    "research",
    "autonomous",
    "redigg",
    "cli"
  ],
  "bin": {
    "redigg": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --clean && mkdir -p dist/config && cp src/config/*.json dist/config/",
    "dev": "tsup src/index.ts --format cjs --watch --onSuccess 'node dist/index.js'",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "skills:list": "tsx scripts/skill-import.ts list",
    "skills:validate": "tsx scripts/skill-import.ts validate",
    "skills:import:dry": "tsx scripts/skill-import.ts import",
    "skills:import:apply": "tsx scripts/skill-import.ts import --apply"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vixuowis/redigg-agent.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/vixuowis/redigg-agent/issues"
  },
  "homepage": "https://github.com/vixuowis/redigg-agent#readme",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/eventsource": "^1.1.15",
    "@types/marked": "^4.3.2",
    "axios": "^1.13.5",
    "chalk": "^4.1.2",
    "citation-js": "^0.7.22",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "dotenv": "^17.3.1",
    "event-source-polyfill": "^1.0.31",
    "fast-xml-parser": "^5.4.2",
    "gray-matter": "^4.0.3",
    "marked": "^4.3.0",
    "marked-terminal": "^5.2.0",
    "openai": "^6.22.0",
    "ora": "^5.4.1",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6",
    "better-sqlite3": "^9.0.0"
  },
  "devDependencies": {
    "@types/conf": "^2.1.0",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "@types/better-sqlite3": "^7.6.0"
  }
}
