{
  "id": "workflow_survey_v1",
  "name": "Survey Research Workflow",
  "description": "A complete workflow for conducting a survey research",
  "type": "survey",
  "variables": {
    "topic": "",
    "max_papers": 10,
    "target_conference": "nips"
  },
  "steps": [
    {
      "id": "step_1",
      "name": "Literature Review",
      "description": "Search for relevant papers and generate a literature review",
      "skill": "literature_review",
      "params": {
        "topic": "${topic}",
        "max_papers": "${max_papers}",
        "categories": ["cs.AI", "cs.LG"]
      },
      "status": "pending"
    },
    {
      "id": "step_2",
      "name": "Peer Review",
      "description": "Generate peer review for the literature review",
      "skill": "peer_review",
      "params": {
        "document_type": "literature_review"
      },
      "status": "pending"
    },
    {
      "id": "step_3",
      "name": "Write Survey",
      "description": "Write the complete survey paper",
      "skill": "paper_writing",
      "params": {
        "conference": "${target_conference}"
      },
      "status": "pending"
    },
    {
      "id": "step_4",
      "name": "Final Review",
      "description": "Final peer review of the complete paper",
      "skill": "peer_review",
      "params": {
        "document_type": "full_paper"
      },
      "status": "pending"
    }
  ]
}
