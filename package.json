{
  "name": "@redigg/redigg",
  "version": "0.1.1",
  "description": "Autonomous Research Agent for Scientific Discovery",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/src/index.js",
  "bin": {
    "redigg": "./dist/src/bin.js"
  },
  "files": [
    "dist",
    "web/dist",
    "skills",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc && rsync -avm --include='*.md' --include='*/' --exclude='*' skills/ dist/skills/ && npm run build --prefix web",
    "start": "node dist/src/index.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" --names \"gateway,ui\" --prefix-colors \"blue,magenta\" --kill-others",
    "dev:backend": "tsx watch src/index.ts",
    "dev:frontend": "npm run dev --prefix web",
    "test": "vitest run",
    "lint": "oxlint",
    "postinstall": "npm install --prefix web",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@agentclientprotocol/sdk": "^0.15.0",
    "@types/node-cron": "^3.0.11",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "eventemitter3": "^5.0.4",
    "express": "^4.22.1",
    "fast-xml-parser": "^5.4.2",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "openai": "^4.28.0",
    "ora": "^9.3.0",
    "pdfkit": "^0.17.2",
    "sqlite-vec": "^0.1.0",
    "tiktoken": "^1.0.22",
    "uuid": "^13.0.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^9.2.1",
    "oxlint": "^0.2.10",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
